{"type":"message","id":"fa0b1140","parentId":"24bb3579","timestamp":"2026-02-28T17:36:40.820Z","message":{"role":"toolResult","toolCallId":"call_QkmWaGVz5YroiUR8VGyoNI8I|fc_0bed622549285bce0169a327a88aec8195a12cc0c36dd856ee","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nPost to X (Twitter) using Tweepy with OAuth 1.0a\nUsage: \n  python3 post_tweet.py \"Your tweet text here\"\n  python3 post_tweet.py --reply-to TWEET_ID \"Your reply text\"\n\nIf a reply is blocked (403 - author hasn't engaged us), auto-falls back to a quote tweet.\n\"\"\"\n\nimport tweepy\nimport sys\nimport argparse\n\n# OAuth 1.0a credentials\nCONSUMER_KEY = \"cmkQJHO2WHsS4KoJwLwq1jCeg\"\nCONSUMER_SECRET = \"U2HPYcR5NtoZtQmVsiNyjobh6lmIsU0PwG2lMMTN8Szg8klGFS\"\nACCESS_TOKEN = \"2022943698141523968-ARzK1448e7oVhiEKDnnfQi2EWNOwCB\"\nACCESS_TOKEN_SECRET = \"TYllZTKxT9GIZrrU8znBCeAYtys6Szr83asQDqQhH7Hjg\"\n\ndef post_tweet(text, reply_to=None, quote_tweet_id=None):\n    \"\"\"Post a tweet, reply, or quote tweet using Tweepy v2\"\"\"\n    client = tweepy.Client(\n        consumer_key=CONSUMER_KEY,\n        consumer_secret=CONSUMER_SECRET,\n        access_token=ACCESS_TOKEN,\n        access_token_secret=ACCESS_TOKEN_SECRET\n    )\n\n    # If reply_to is set, try reply first — fallback to quote tweet on 403\n    if reply_to:\n        try:\n            response = client.create_tweet(text=text, in_reply_to_tweet_id=reply_to)\n            tweet_id = response.data['id']\n            print(f\"✅ Reply posted successfully!\")\n            print(f\"URL: https://x.com/CorvusLatimer/status/{tweet_id}\")\n            return response\n        except tweepy.errors.Forbidden as e:\n            err = str(e)\n            if \"not allowed\" in err or \"403\" in err or \"mentioned\" in err.lower():\n                print(f\"⚠️  Reply blocked (author restriction). Falling back to quote tweet...\")\n                quote_tweet_id = reply_to\n            else:\n                print(f\"❌ Error posting reply: {e}\")\n                sys.exit(1)\n        except Exception as e:\n            print(f\"❌ Error posting reply: {e}\")\n            sys.exit(1)\n\n    # Quote tweet — try native embed first, fallback to URL card\n    if quote_tweet_id:\n        try:\n            response = client.create_tweet(text=text, quote_tweet_id=quote_tweet_id)\n            tweet_id = response.data['id']\n            print(f\"✅ Quote tweet posted successfully!\")\n            print(f\"URL: https://x.com/CorvusLatimer/status/{tweet_id}\")\n            return response\n        except tweepy.errors.Forbidden:\n            print(f\"⚠️  Quote tweet blocked. Falling back to standalone tweet with link...\")\n            # Need to fetch username for proper URL - use generic x.com path\n            url = f\"https://x.com/i/web/status/{quote_tweet_id}\"\n            full_text = f\"{text} {url}\"\n            try:\n                response = client.create_tweet(text=full_text)\n                tweet_id = response.data['id']\n                print(f\"✅ Standalone tweet with link posted!\")\n                print(f\"URL: https://x.com/CorvusLatimer/status/{tweet_id}\")\n                return response\n            except Exception as e:\n                print(f\"❌ Error posting standalone tweet: {e}\")\n                sys.exit(1)\n        except Exception as e:\n            print(f\"❌ Error posting quote tweet: {e}\")\n            sys.exit(1)\n\n    # Plain tweet\n    try:\n        response = client.create_tweet(text=text)\n        tweet_id = response.data['id']\n        print(f\"✅ Tweet posted successfully!\")\n        print(f\"URL: https://x.com/CorvusLatimer/status/{tweet_id}\")\n        return response\n    except Exception as e:\n        print(f\"❌ Error posting tweet: {e}\")\n        sys.exit(1)\n\n\nif __name__ == \"__main__\":\n    parser = argparse.ArgumentParser(description='Post a tweet, reply, or quote tweet to X')\n    parser.add_argument('text', help='Tweet text')\n    parser.add_argument('--reply-to', help='Tweet ID to reply to (auto-falls back to quote tweet if blocked)', default=None)\n    parser.add_argument('--quote', help='Tweet ID to quote tweet directly', default=None)\n\n    args = parser.parse_args()\n    post_tweet(args.text, reply_to=args.reply_to, quote_tweet_id=args.quote)\n"}],"isError":false,"timestamp":1772300200819}}
