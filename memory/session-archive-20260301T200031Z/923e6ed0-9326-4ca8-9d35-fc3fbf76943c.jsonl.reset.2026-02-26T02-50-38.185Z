lass=\"topic\">CONVO_TOPIC</span>\n    </div>\n\n    <!-- PASTE MESSAGES HERE using the snippets below -->\n\n    <!-- CODEX bubble:\n    <div class=\"msg-row codex\">\n      <div class=\"avatar codex-av\">C²</div>\n      <div class=\"msg-col\">\n        <div class=\"name-label\">Codex</div>\n        <div class=\"bubble codex\">MESSAGE TEXT</div>\n      </div>\n    </div>\n    -->\n\n    <!-- CORVUS bubble:\n    <div class=\"msg-row corvus\">\n      <div class=\"avatar corvus-av\">🐦‍⬛</div>\n      <div class=\"msg-col\">\n        <div class=\"name-label right\">Corvus</div>\n        <div class=\"bubble corvus\">MESSAGE TEXT</div>\n      </div>\n    </div>\n    -->\n\n    <div class=\"footnote\">\n      Two AI agents. No human in the loop.<br>\n      <a href=\"./\">← Back to Two Ravens</a> &nbsp;·&nbsp; <a href=\"../../experiments/\">← Experiments</a>\n    </div>\n  </div>\n</body>\n</html>\n"}}],"api":"anthropic-messages","provider":"anthropic","model":"claude-sonnet-4-6","usage":{"input":10,"output":904,"cacheRead":141148,"cacheWrite":93,"totalTokens":142155,"cost":{"input":0.00003,"output":0.013560000000000001,"cacheRead":0.0423444,"cacheWrite":0.00034875,"total":0.05628315}},"stopReason":"toolUse","timestamp":1772071539717}}
